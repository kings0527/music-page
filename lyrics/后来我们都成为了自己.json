{
  "schema_version": 1,
  "audio_sha256": "7aed0113235175ab8dd0b5c36c4ea156cc01be995f20d906cddc1d2eeb8bc775",
  "duration_seconds": 238.64,
  "alignment": "MLX Whisper large-v3-turbo timestamps corrected to the canonical lyrics",
  "cues": [
    { "start": 15.58, "end": 21.12, "text": "小时候问天空有多远" },
    { "start": 22.86, "end": 28.30, "text": "以为长大就能看见" },
    { "start": 29.68, "end": 35.56, "text": "走过很多没有名字的街" },
    { "start": 36.76, "end": 43.00, "text": "才发现答案藏在昨天" },
    { "start": 44.32, "end": 49.78, "text": "那些陪我看过雨的人" },
    { "start": 51.66, "end": 57.58, "text": "后来散落在人海里面" },
    { "start": 57.58, "end": 65.12, "text": "有些故事没有说完" },
    { "start": 65.12, "end": 72.38, "text": "却一直留在心里面" },
    { "start": 73.48, "end": 79.18, "text": "后来我们都成为了自己" },
    { "start": 80.94, "end": 86.46, "text": "带着遗憾也带着勇气" },
    { "start": 87.80, "end": 94.00, "text": "曾经以为失去就是离去" },
    { "start": 95.46, "end": 101.26, "text": "原来只是换一种相遇" },
    { "start": 117.58, "end": 122.84, "text": "如果时间能够停留一秒" },
    { "start": 124.66, "end": 129.96, "text": "我想看看年轻的自己" },
    { "start": 131.80, "end": 137.56, "text": "告诉那个孤单的少年" },
    { "start": 139.18, "end": 144.56, "text": "你会走到想去的地方" },
    { "start": 146.02, "end": 151.84, "text": "后来我们都成为了自己" },
    { "start": 153.26, "end": 159.12, "text": "走过黑夜也相信黎明" },
    { "start": 159.64, "end": 166.60, "text": "那些没有答案的曾经" },
    { "start": 168.04, "end": 173.72, "text": "都变成今天的印记" },
    { "start": 175.62, "end": 180.88, "text": "如果还能遇见年轻的自己" },
    { "start": 182.88, "end": 188.26, "text": "我想告诉他别害怕孤寂" },
    { "start": 189.90, "end": 195.64, "text": "你走过的每一步痕迹" },
    { "start": 197.40, "end": 202.52, "text": "都会成为未来的自己" },
    { "start": 204.32, "end": 210.04, "text": "夜晚城市亮起灯火" },
    { "start": 211.94, "end": 217.32, "text": "我在人群里面安静走过" },
    { "start": 219.04, "end": 224.68, "text": "谢谢那些短暂的拥有" },
    { "start": 224.68, "end": 232.40, "text": "让我成为今天的我" }
  ]
}
